# Copy this file to ".env" and fill in real values. NEVER commit .env.
PORT=5000

# Where the client is served from (for CORS). Update to the deployed URL later.
CORS_ORIGIN=http://localhost:5500

# TMDB API key (themoviedb.org -> Settings -> API). Used server-side only.
TMDB_KEY=your_tmdb_api_key_here

# MongoDB Atlas connection string (added after Thursday's Mongo lecture).
MONGODB_URI=your_mongodb_atlas_connection_string_here

# Long random string used to sign JWTs.
JWT_SECRET=change_me_to_a_long_random_string
