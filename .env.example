# Copy this file to ".env" and fill in real values. NEVER commit .env.

# TMDB API v3 key (themoviedb.org -> Settings -> API -> "API Key (v3 auth)").
# Used server-side only; the frontend never sees it.
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Port the proxy listens on (defaults to 3000 if unset). On Render, leave this
# UNSET — the platform injects its own PORT.
PORT=3000

# Optional: comma-separated CORS allowlist. Overrides the built-in defaults
# (movieknight.site, www.movieknight.site, and local dev origins). Set this in
# production if your frontend is served from a different domain, e.g.
#   CORS_ORIGINS=https://movieknight.site,https://www.movieknight.site
# CORS_ORIGINS=

MONGODB_URI=your_mongo_db_uri

# Secret used to sign/verify auth JWTs. Use any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret

# Google Gemini API key (free tier: aistudio.google.com -> "Get API key").
# Powers the AI features (/api/ai/*). Optional — the server still boots without
# it; the AI endpoints just return a 500 until it's set.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini overrides. GEMINI_MODEL defaults to gemini-1.5-flash (fast +
# free-tier friendly, supports JSON mode); GEMINI_TIMEOUT_MS caps a single call.
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_TIMEOUT_MS=20000