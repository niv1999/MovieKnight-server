# Copy to ".env" and fill in real values. Never commit .env.

# TMDB v3 key (server-side only; the client never sees it).
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Defaults to 3000. Leave UNSET on Render (it injects its own PORT).
PORT=3000

# Optional CORS allowlist (comma-separated). Overrides the built-in defaults.
# CORS_ORIGINS=https://movieknight.site,https://www.movieknight.site

MONGODB_URI=your_mongo_db_uri

# JWT signing secret. Any long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret

# Optional. Powers /api/ai/*; the server still boots without it (those routes 500).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini overrides.
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_TIMEOUT_MS=20000

# Daily AI actions per user (default 5).
AI_DAILY_LIMIT=5
