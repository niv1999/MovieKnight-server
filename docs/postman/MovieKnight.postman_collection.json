{
  "info": {
    "name": "MovieKnight API",
    "_postman_id": "movieknight-api-collection",
    "description": "MovieKnight server (Node/Express + MongoDB).\n\n- External API: TMDB (proxied server-side; key stays in .env).\n- JS library embedded (client): Toastify.\n- Response envelope under /api: success { ok:true, data }, error { ok:false, error }.\n- Auth: protected routes need `Authorization: Bearer <token>`. Signup/Login auto-save the token to the {{token}} variable.\n\nSet {{baseUrl}} to your dev (http://localhost:3000) or deployed URL.\n\nNOTE: Collections + Wheel routes are specified in docs/API_CONTRACT.md but land in S5–S6; they are not in this collection yet because they are not implemented on the server.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Signup / login / me (S4). bcryptjs + JWT. Envelope { ok, data } / { ok, error }.",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Save the JWT to the {{token}} collection variable for the /me request.",
                  "var d = pm.response.json();",
                  "if (d && d.data && d.data.token) {",
                  "  pm.collectionVariables.set('token', d.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ada Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"username\": \"ada\",\n  \"password\": \"secret123\",\n  \"dateOfBirth\": \"1990-12-10\"\n}",
